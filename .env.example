# Copie este arquivo para ".env" (uso local) e/ou configure essas mesmas
# variáveis no painel da Vercel em Settings > Environment Variables.

# Access Token de PRODUÇÃO da sua conta Mercado Pago
# (Painel MP > Seu negócio > Configurações > Credenciais > Credenciais de produção)
MERCADOPAGO_ACCESS_TOKEN=

# URL final do site depois de publicado (com https://), usada para o
# Mercado Pago saber pra onde mandar o cliente depois do pagamento.
SITE_URL=https://seudominio.com.br
